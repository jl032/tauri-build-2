{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vikunja",
  "version": "0.1.0",
  "identifier": "com.jonat.vikunja",
  "build": {
    "devUrl": "http://localhost:3456",
    "beforeBuildCommand": "",
    "frontendDist": "http://localhost:3456"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vikunja",
        "width": 1280,
        "height": 800,
        "url": "http://localhost:3456"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
