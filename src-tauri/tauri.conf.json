{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Feeder",
  "version": "0.1.0",
  "identifier": "com.jonat.feeder",
  "build": {
    "devUrl": "https://feeder.co/reader",
    "beforeBuildCommand": "",
    "frontendDist": "https://feeder.co/reader"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Feeder",
        "url": "https://feeder.co/reader/",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
